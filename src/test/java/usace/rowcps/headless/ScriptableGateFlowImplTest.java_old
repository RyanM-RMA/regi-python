public class ScriptableGateFlowImplTest extends UiRegiDomainTest

{

	public ScriptableGateFlowImplTest()
	{
	}

	@Test
	public void testSomeMethod()
	{
		ScriptableGateFlowCalc cal = new ScriptableGateFlowImpl(getRegiDomain(), getManagerId());

		Calendar startCal = Calendar.getInstance();
		startCal.clear();
		startCal.set(2015, 3, 2, 12, 6);


		long startTime = startCal.getTimeInMillis();



		Calendar endCal = Calendar.getInstance();
		endCal.clear();
		endCal.set(Calendar.YEAR, 2015);
		endCal.set(Calendar.MONTH, 6);
		long endTime = endCal.getTimeInMillis();
//start 1430463600000
		// end 1435734000000
		cal.computeFlowGroup("SWF", "LEWT2", startTime, endTime, "Flow.LEWT2.ConduitGate_Total");

	}

